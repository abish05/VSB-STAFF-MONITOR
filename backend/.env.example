# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/codepulse
# For Neon: postgresql+asyncpg://user:pass@ep-xxx.neon.tech/codepulse?ssl=require

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# For Upstash: rediss://default:your-token@your-host.upstash.io:6379

# ─── AI ───────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ─── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your-personal-access-token-here

# ─── App Config ───────────────────────────────────────────────────────────────
APP_NAME=CodePulse AI
APP_ENV=development
DEBUG=true
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
COLLEGE_NAME=VSB Engineering College

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@codepulse.ai
# Optional: SendGrid
SENDGRID_API_KEY=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100
AUTH_RATE_LIMIT_PER_MINUTE=20

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
